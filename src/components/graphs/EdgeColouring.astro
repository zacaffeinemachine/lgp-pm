---
// A 2-colouring of K_4: red (solid) edges {12,24,14} form a monochromatic
// triangle on {1,2,4}; blue (dashed) edges {23,34,13} do not.
interface Props { caption?: string; }
const { caption } = Astro.props;

// K_4 vertices on a square (labels 1..4), centre (120,100), r=70.
const V: Record<number, [number, number]> = {
  1: [169.5, 50.5],
  2: [70.5, 50.5],
  3: [70.5, 149.5],
  4: [169.5, 149.5],
};
const red = [ [1,2], [2,4], [1,4] ];
const blue = [ [2,3], [3,4], [1,3] ];
---
<figure class="not-prose my-8 flex flex-col items-center">
  <svg viewBox="0 0 240 210" width="250" class="max-w-full" role="img" aria-label="A two-colouring of K4 with a monochromatic triangle">
    <g stroke-linecap="round" fill="none">
      {blue.map(([a, b]) => (
        <line x1={V[a][0]} y1={V[a][1]} x2={V[b][0]} y2={V[b][1]}
          stroke="var(--muted)" stroke-width="2" stroke-dasharray="5 5" />
      ))}
      {red.map(([a, b]) => (
        <line x1={V[a][0]} y1={V[a][1]} x2={V[b][0]} y2={V[b][1]}
          stroke="var(--accent)" stroke-width="3" />
      ))}
    </g>
    <g fill="var(--ink)">
      {Object.values(V).map(([x, y]) => <circle cx={x} cy={y} r="6" />)}
    </g>
    <g fill="var(--muted)" font-size="13" font-family="serif">
      <text x="169.5" y="40" text-anchor="middle">1</text>
      <text x="70.5" y="40" text-anchor="middle">2</text>
      <text x="62" y="164" text-anchor="middle">3</text>
      <text x="178" y="164" text-anchor="middle">4</text>
    </g>
    <g font-size="13" font-family="serif">
      <text x="40" y="200" fill="var(--accent)">— red</text>
      <text x="150" y="200" fill="var(--muted)">-- blue</text>
    </g>
  </svg>
  {caption && <figcaption class="text-sm text-[var(--muted)] mt-2 max-w-md text-center">{caption}</figcaption>}
</figure>
