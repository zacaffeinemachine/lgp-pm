---
// One graph, two highlights. Left: a clique {1,2,3} (mutually adjacent).
// Right: an independent set {2,4} (no edge between them).
interface Props { caption?: string; }
const { caption } = Astro.props;

function pentagon(cx: number, cy: number, r: number) {
  return [90, 162, 234, 306, 18].map((a) => {
    const t = (a * Math.PI) / 180;
    return [
      +(cx + r * Math.cos(t)).toFixed(1),
      +(cy - r * Math.sin(t)).toFixed(1),
    ] as [number, number];
  });
}
const L = pentagon(110, 90, 60);
const R = pentagon(330, 90, 60);
// edges by 0-based vertex index (labels 1..5): triangle 1-2-3 plus 3-4,4-5,5-1
const E = [ [0,1], [1,2], [0,2], [2,3], [3,4], [4,0] ];
const cliqueE = [ [0,1], [1,2], [0,2] ];
const cliqueV = [0, 1, 2];
const indepV = [1, 3];

function isEdge(set: number[][], a: number, b: number) {
  return set.some(([x, y]) => (x === a && y === b) || (x === b && y === a));
}
---
<figure class="not-prose my-8 flex flex-col items-center">
  <svg viewBox="0 0 440 195" width="440" class="max-w-full" role="img" aria-label="A clique and an independent set in the same graph">
    <!-- LEFT graph with clique highlighted -->
    <g stroke="var(--ink)" stroke-width="2" stroke-linecap="round" opacity="0.55">
      {E.map(([a, b]) => (
        <line x1={L[a][0]} y1={L[a][1]} x2={L[b][0]} y2={L[b][1]}
          stroke={isEdge(cliqueE, a, b) ? "var(--accent)" : "var(--ink)"}
          stroke-width={isEdge(cliqueE, a, b) ? 3 : 2}
          opacity={isEdge(cliqueE, a, b) ? 0.9 : 0.55} />
      ))}
    </g>
    <g>
      {L.map(([x, y], i) => (
        <circle cx={x} cy={y} r="6.5" fill={cliqueV.includes(i) ? "var(--accent)" : "var(--ink)"} />
      ))}
    </g>
    <!-- RIGHT graph with independent set highlighted -->
    <g stroke="var(--ink)" stroke-width="2" stroke-linecap="round" opacity="0.55">
      {E.map(([a, b]) => (
        <line x1={R[a][0]} y1={R[a][1]} x2={R[b][0]} y2={R[b][1]} />
      ))}
    </g>
    <g>
      {R.map(([x, y], i) => (
        <>
          <circle cx={x} cy={y} r="6.5" fill="var(--ink)" />
          {indepV.includes(i) && (
            <circle cx={x} cy={y} r="11" fill="none" stroke="var(--accent)" stroke-width="2.5" />
          )}
        </>
      ))}
    </g>
    <!-- vertex numbers -->
    <g fill="var(--muted)" font-size="13" font-family="serif">
      {L.map(([x, y], i) => (
        <text x={x} y={y - 13} text-anchor="middle">{i + 1}</text>
      ))}
      {R.map(([x, y], i) => (
        <text x={x} y={y - 13} text-anchor="middle">{i + 1}</text>
      ))}
    </g>
    <g fill="var(--muted)" font-size="15" font-family="serif">
      <text x="110" y="188" text-anchor="middle">clique {`{1,2,3}`}</text>
      <text x="330" y="188" text-anchor="middle">independent {`{2,4}`}</text>
    </g>
  </svg>
  {caption && <figcaption class="text-sm text-[var(--muted)] mt-2 max-w-lg text-center">{caption}</figcaption>}
</figure>
