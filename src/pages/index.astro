---
import Base from "../layouts/Base.astro";
import ChapterCard from "../components/ChapterCard.astro";
import { isChapterVisible } from "../config/visibility.ts";

const base = import.meta.env.BASE_URL;

// Hand-curated day list — order and blurbs matter pedagogically.
// Visibility is controlled in src/config/visibility.ts.
// `kind: "day"` chapters are numbered Day 1, Day 2, …; `kind: "appendix"`
// chapters carry no day number and show an "Appendix" kicker instead.
const allChapters = [
  {
    slug: "day1",
    title: "Foundations",
    kind: "day",
    blurb: "Sample spaces, events, and the uniform measure — plus a coin-flip betting game that almost nobody wins. Where chance becomes something you can compute.",
  },
  {
    slug: "day2",
    title: "Random Variables, Expectation, and Linearity",
    kind: "day",
    blurb: "Readouts of an experiment, their averages, and the one rule that runs the rest of the week: the expectation of a sum is the sum of the expectations — no matter how the parts interact.",
  },
  // Days 3–5 and the bonus material will appear here as they're built.
  {
    slug: "appendix",
    title: "A Primer on Graphs",
    kind: "appendix",
    blurb: "Vertices, edges, degrees, cliques, and colourings — the modest graph-theory vocabulary the workshop leans on, opened by the 1512 knight-swap puzzle of Guarini.",
  },
];

// Keep day numbering stable regardless of where appendices sit in the list.
let dayCount = 0;
const chapters = allChapters
  .filter((c) => isChapterVisible(c.slug))
  .map((c) => ({
    ...c,
    kicker: c.kind === "appendix" ? "Appendix" : `Day ${++dayCount}`,
  }));
---
<Base title="The Probabilistic Method" description="A five-day workshop on the probabilistic method, for mathematically curious high-school students.">
  <section class="mb-16">
    <h1 class="text-4xl font-semibold tracking-tight mb-4">The Probabilistic Method</h1>
    <p class="prose text-lg text-[var(--muted)]">
      A five-day workshop on one of the most beautiful ideas in mathematics:
      to prove that something <em>exists</em>, build it at random and show the
      odds are in your favour. Each day pairs a short lecture with games and
      simulations you can play with right here.
    </p>
  </section>

  <section class="grid gap-4 md:grid-cols-2">
    {chapters.map((c) => (
      <ChapterCard
        href={`${base}/${c.slug}/`}
        title={c.title}
        blurb={c.blurb}
        kicker={c.kicker}
      />
    ))}
  </section>
</Base>
